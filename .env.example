# Edit these for local development
# In production; these are set as secrets in GitHub and referenced in the deploy workflow.

# AI API Configuration
OLLAMA_API_URL=http://example-ollama-api.com
OLLAMA_MODEL=gpt-oss

# MaxMind credentials for GeoLocation of IP addresses.
# Used by scripts/download-geoip.js to auto-download the GeoLite2-City database.
# Leave blank to disable geolocation (location fields stay empty).
MAXMIND_ACCOUNT_ID=123456
MAXMIND_LICENSE_KEY=your_key_here

# PostgreSQL connection string used by the server-side user store.
# For local development against the docker-compose `db` service:
DATABASE_URL=postgres://spelwijsheid_user:spelwijsheid_password@localhost:5432/spelwijsheid

# Where the GeoLite2-City database is written/read. In Docker this defaults to
# /app/geoip/GeoLite2-City.mmdb. For local runs, set a writable local path:
# GEOIP_DB_PATH=./geoip/GeoLite2-City.mmdb

# Secret salt for the device fingerprints used to group a person's instances
# (browsers/devices) for analytics. Set a random value in production.
FINGERPRINT_SALT=change-me

# Postgres credentials consumed by docker-compose (defaults shown).
POSTGRES_USER=spelwijsheid_user
POSTGRES_PASSWORD=spelwijsheid_password
POSTGRES_DB=spelwijsheid