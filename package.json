		"@types/node": "^25",
		"eslint": "^9.39.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.3.0",
		"husky": "^9.1.7",
		"prettier": "^3.8.1",
