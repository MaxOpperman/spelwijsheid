{
	"name": "spelwijsheid",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"preinstall": "node scripts/download-wordlist.js",
		"download-wordlist": "node scripts/download-wordlist.js",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:style": "prettier --check . && eslint .",
