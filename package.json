		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.66.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^26.0.0",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.3",
