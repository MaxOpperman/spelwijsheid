{
	"name": "spelwijsheid",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"preinstall": "node scripts/download-wordlist.js",
		"download:wordlist": "node scripts/download-wordlist.js",
		"download:geoip": "node --env-file-if-exists=.env scripts/download-geoip.js",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:style": "prettier --check . && eslint .",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "eslint . --fix",
		"test": "vitest",
		"test:e2e": "playwright test",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"maxmind": "^5.0.0",
		"pg": "^8.13.1",
		"ua-parser-js": "^2.0.6"
	},
	"devDependencies": {
		"@electric-sql/pglite": "^0.5.4",
		"@electric-sql/pglite-socket": "^0.2.6",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@fontsource/fira-mono": "^5.2.7",
		"@neoconfetti/svelte": "^2.2.2",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.66.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^26.0.0",
		"@types/pg": "^8.11.10",
		"drizzle-kit": "^0.31.5",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"leaflet": "^1.9.4",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1",
		"vite": "^8.1.4",
		"vite-plugin-static-copy": "^4.1.1",
		"vitest": "^4.1.9"
	}
}
